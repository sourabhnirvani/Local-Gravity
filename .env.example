# LocalGravity Environment Configuration

# SMTP Server Credentials for sending feedback emails
# The SMTP User defaults to 'novaaidrive@gmail.com' if left blank.
SMTP_USER=novaaidrive@gmail.com

# SMTP Password (For Gmail, you MUST use a 16-character App Password, NOT your normal Gmail password)
# Learn how to create one: https://support.google.com/accounts/answer/185833
SMTP_PASS=your_16_character_gmail_app_password
